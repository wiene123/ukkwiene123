# Database Configuration (Aiven / External)
MYSQLHOST=your_aiven_host
MYSQLUSER=your_aiven_user
MYSQLPASSWORD=your_aiven_password
MYSQLDATABASE=your_aiven_db_name
MYSQLPORT=your_aiven_port

# Local Dev Defaults
# If you are running locally with XAMPP, you don't need this file.
# This is a guide for Vercel Environment Variables.
